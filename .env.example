## Airtable
# PAT (Personal Access Token) con permisos a tu base
# - Para los scripts Node: AIRTABLE_PAT
# - Para el frontend (Vite): VITE_AIRTABLE_PAT (Vite solo expone variables que empiezan con VITE_)
AIRTABLE_PAT=your_airtable_pat_here
VITE_AIRTABLE_PAT=your_airtable_pat_here

# ID de la Base en Airtable (appXXXXXXXXXXXXXX)
BASE_ID=your_base_id_here
VITE_BASE_ID=your_base_id_here

# (Opcional) ID de la tabla CURSOS si vas a usar scripts meta
TABLE_ID=your_table_id_here
VITE_TABLE_ID=your_table_id_here

